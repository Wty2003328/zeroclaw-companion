{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZeroClaw Companion",
  "version": "0.1.0",
  "identifier": "ai.zeroclaw.companion",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../../web run dev",
    "beforeBuildCommand": "npm --prefix ../../web run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ZeroClaw Companion",
        "width": 1100,
        "height": 760,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "url": "/"
      },
      {
        "label": "avatar",
        "title": "Avatar",
        "url": "/avatar",
        "width": 400,
        "height": 540,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false
      }
    ],
    "security": {
      "csp": "default-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self' 'unsafe-inline' http://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; img-src 'self' http://127.0.0.1:* data:; media-src 'self' blob: http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/companion-server"
    ]
  },
  "plugins": {}
}
