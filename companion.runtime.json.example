    "model": "gpt-4o-mini",
    "base_url": "https://api.openai.com/v1",
    "timeout_secs": 30,
    "disable_thinking": false,
    "enabled": null,
    "only_when_translating": null,
    "streaming": null,
    "translator": {
      "backend": null,
      "url": null,
      "http_timeout_secs": null,
      "nmt_quality_preset": null,
      "nmt_model_id": null,
      "nmt_num_beams": null,
      "nmt_device": null,
      "nmt_precision": null,
      "nmt_src_lang": null,
      "nmt_tgt_lang": null,
      "nmt_launch_command": null,
      "nmt_auto_start": null,
      "nmt_close_with_companion": null,
      "nmt_port": null
    }
  },

  "zeroclaw": {
    "kind": "zeroclaw",
    "url": "http://127.0.0.1:42617",
    "pair_token": null,
    "timeout_secs": 300
  }
